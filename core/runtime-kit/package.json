{
    "name": "@napgram/runtime-kit",
    "version": "0.2.0",
    "description": "Runtime exports for NapGram web interfaces",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "publishConfig": {
        "main": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "exports": {
            ".": {
                "types": "./dist/index.d.ts",
                "import": "./dist/index.js",
                "default": "./dist/index.js"
            },
            "./package.json": "./package.json"
        }
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "dev": "tsc -p tsconfig.json --watch"
    },
    "keywords": [
        "napgram",
        "runtime"
    ],
    "author": "NapGram Team",
    "license": "MIT",
    "dependencies": {
        "@napgram/infra-kit": "workspace:*",
        "@napgram/media-kit": "workspace:*",
        "@napgram/qq-client": "workspace:*",
        "@napgram/telegram-client": "workspace:*",
        "yaml": "^2.8.2"
    },
    "devDependencies": {
        "@types/node": "25.5.0",
        "typescript": "5.9.3"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ]
}
