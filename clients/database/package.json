{
    "name": "@napgram/database",
    "version": "0.1.2",
    "description": "Database abstraction layer for NapGram with Drizzle ORM",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./schema": {
            "types": "./dist/schema/index.d.ts",
            "import": "./dist/schema/index.js",
            "default": "./dist/schema/index.js"
        }
    },
    "publishConfig": {
        "main": "./dist/index.js",
        "types": "./dist/index.d.ts"
    },
    "scripts": {
        "build": "rm -rf dist && tsc -p tsconfig.json",
        "dev": "tsc -p tsconfig.json --watch",
        "lint": "eslint . --ext .ts,.tsx",
        "test": "vitest --passWithNoTests",
        "type-check": "tsc --noEmit",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push"
    },
    "keywords": [
        "napgram",
        "database",
        "orm",
        "drizzle"
    ],
    "author": "NapGram Team",
    "license": "MIT",
    "dependencies": {
        "drizzle-orm": "^0.45.1",
        "pg": "^8.16.3"
    },
    "devDependencies": {
        "@types/node": "25.5.2",
        "@types/pg": "^8.16.0",
        "drizzle-kit": "^0.31.8",
        "typescript": "6.0.2",
        "vitest": "4.1.3"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ]
}
