{
    "name": "@napgram/qq-client",
    "version": "0.1.7",
    "description": "Shared QQ client for NapGram",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "tsc -b",
        "dev": "tsc -b -w",
        "test": "vitest run --passWithNoTests"
    },
    "keywords": [
        "napgram",
        "qq",
        "client"
    ],
    "author": "NapGram Team",
    "license": "MIT",
    "dependencies": {
        "@naplink/naplink": "^0.0.10"
    },
    "devDependencies": {
        "@types/node": "25.5.0",
        "typescript": "6.0.2",
        "vitest": "4.1.2"
    },
    "publishConfig": {
        "main": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "exports": {
            ".": {
                "types": "./dist/index.d.ts",
                "import": "./dist/index.js",
                "default": "./dist/index.js"
            },
            "./package.json": "./package.json"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ]
}
