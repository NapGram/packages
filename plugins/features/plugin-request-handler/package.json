{
    "name": "@napgram/plugin-request-handler",
    "version": "0.1.8",
    "description": "NapGram request intake and automation plugin",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "dev": "tsc -p tsconfig.json --watch"
    },
    "keywords": [
        "napgram",
        "plugin",
        "requests",
        "automation"
    ],
    "author": "NapGram Team",
    "license": "MIT",
    "devDependencies": {
        "@napgram/sdk": "workspace:*",
        "@types/node": "25.5.0",
        "typescript": "6.0.2"
    },
    "publishConfig": {
        "main": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "exports": {
            ".": {
                "types": "./dist/index.d.ts",
                "import": "./dist/index.js",
                "default": "./dist/index.js"
            },
            "./package.json": "./package.json"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "dependencies": {
        "@napgram/request-kit": "workspace:*"
    }
}
