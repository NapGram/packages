{
    "name": "@napgram/auth-kit",
    "version": "0.1.13",
    "description": "Authentication utilities for NapGram",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "dev": "tsc -p tsconfig.json --watch"
    },
    "keywords": [
        "napgram",
        "auth"
    ],
    "author": "NapGram Team",
    "license": "MIT",
    "dependencies": {
        "@napgram/db-kit": "workspace:*",
        "@napgram/infra-kit": "workspace:*",
        "@napgram/logger-kit": "workspace:*",
        "@napgram/qq-client": "workspace:*",
        "fastify": "5.8.5"
    },
    "devDependencies": {
        "@fastify/cookie": "^11.0.2",
        "@types/node": "25.6.0",
        "typescript": "6.0.2"
    },
    "publishConfig": {
        "main": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "exports": {
            ".": {
                "types": "./dist/index.d.ts",
                "import": "./dist/index.js",
                "default": "./dist/index.js"
            },
            "./package.json": "./package.json"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ]
}
