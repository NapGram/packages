{
    "name": "@napgram/gateway-kit",
    "version": "0.2.4",
    "description": "Gateway exports for NapGram",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "dev": "tsc -p tsconfig.json --watch"
    },
    "dependencies": {
        "@mtcute/core": "^0.29.1",
        "@mtcute/node": "^0.29.1",
        "@napgram/message-kit": "workspace:*",
        "@napgram/qq-client": "workspace:*",
        "@napgram/telegram-client": "workspace:*",
        "ws": "^8.18.3"
    },
    "keywords": [
        "napgram",
        "gateway"
    ],
    "author": "NapGram Team",
    "license": "MIT",
    "devDependencies": {
        "@types/node": "25.6.0",
        "@types/ws": "^8.18.1",
        "typescript": "6.0.3"
    },
    "publishConfig": {
        "main": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "exports": {
            ".": {
                "types": "./dist/index.d.ts",
                "import": "./dist/index.js",
                "default": "./dist/index.js"
            },
            "./package.json": "./package.json"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ]
}
