{
    "name": "@napgram/web-interfaces",
    "version": "0.3.5",
    "description": "Shared web route modules for NapGram",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "dev": "tsc -p tsconfig.json --watch"
    },
    "dependencies": {
        "@fastify/multipart": "^9.3.0",
        "@kitajs/html": "^4.2.11",
        "@napgram/auth-kit": "workspace:*",
        "@napgram/db-kit": "workspace:*",
        "@napgram/env-kit": "workspace:*",
        "@napgram/infra-kit": "workspace:*",
        "@napgram/logger-kit": "workspace:*",
        "@napgram/message-kit": "workspace:*",
        "@napgram/plugin-kit": "workspace:*",
        "@napgram/runtime-kit": "workspace:*",
        "@napgram/telegram-client": "workspace:*",
        "fastify": "5.8.4",
        "zod": "4.3.6"
    },
    "keywords": [
        "napgram",
        "web",
        "interfaces"
    ],
    "author": "NapGram Team",
    "license": "MIT",
    "devDependencies": {
        "@fastify/cookie": "^11.0.2",
        "@kitajs/ts-html-plugin": "^4.1.3",
        "@types/node": "25.5.0",
        "typescript": "6.0.2"
    },
    "publishConfig": {
        "main": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "exports": {
            ".": {
                "types": "./dist/index.d.ts",
                "import": "./dist/index.js",
                "default": "./dist/index.js"
            },
            "./package.json": "./package.json"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ]
}
